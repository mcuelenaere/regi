<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>
    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>
    <key>LSApplicationCategoryType</key>
    <string>public.app-category.utilities</string>
    <key>LSMinimumSystemVersion</key>
    <string>$(MACOSX_DEPLOYMENT_TARGET)</string>
    <key>NSPrincipalClass</key>
    <string>NSApplication</string>
    <key>NSHumanReadableCopyright</key>
    <string></string>
    <!--
        JetKVM devices ship with self-signed TLS certificates by default.
        With ATS active, the network stack fails the TLS handshake at the
        BoringSSL layer before URLSession can invoke our trust delegate to
        override. Disabling ATS (combined with the user-opt-in trust check
        in TLSDelegate) lets the delegate fire so we can accept the cert.
        This app only ever connects to a single user-chosen device per
        session, so the practical attack surface is small.
    -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <true/>
    </dict>
    <!--
        Local-network access for mDNS / Bonjour discovery of JetKVM
        (_jetkvm._tcp) and PiKVM (_pikvm._tcp) devices on the LAN.
        macOS prompts the user the first time the app browses for these
        services. Without these keys, NetServiceBrowser never returns
        results on macOS 14+ even if the device is broadcasting
        correctly — each browsed service type must be listed here.
    -->
    <key>NSLocalNetworkUsageDescription</key>
    <string>Used to discover JetKVM and PiKVM devices on your local network.</string>
    <key>NSBonjourServices</key>
    <array>
        <string>_jetkvm._tcp</string>
        <string>_pikvm._tcp</string>
    </array>
    <!--
        Don't save window state on quit. macOS's "Reopen windows on
        logon" path was reopening empty session windows because
        SwiftUI's WindowGroup(for: Codable) auto-restores per-value
        bindings. With this set to false, AppKit doesn't persist any
        window state, so there's nothing to restore — the app always
        launches fresh into HostsView.
    -->
    <key>NSQuitAlwaysKeepsWindows</key>
    <false/>
</dict>
</plist>
